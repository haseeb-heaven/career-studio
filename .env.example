PORT=3001

# Optional cloud LLM providers (server-side). Leave blank to disable.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Default models (used when a request doesn't specify one)
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest
OPENROUTER_MODEL=openai/free

# Backend configuration
DATABASE_URL=sqlite:///./career_studio.db
CORS_ORIGINS=http://localhost:5173

# Frontend server (Vite dev server)
FRONTEND_HOST=localhost
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173

# Backend server
BACKEND_HOST=localhost
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# Frontend configuration (set in frontend/.env.local)
VITE_API_BASE_URL=http://localhost:8000/api

# Deployment: set these to your production URLs
# CORS_ORIGINS=https://your-app.vercel.app,https://your-domain.com
# VITE_API_BASE_URL=https://your-backend.railway.app/api

TESTSPRITE_API_KEY=
