# Copy this to .env and fill in your keys. The backend auto-loads it on startup.

# ── AI Provider (pick one and fill in the key) ────────────────────────────────
# Used as fallback if the Settings tab in the UI has no key set.

# OpenRouter (free models available — recommended for getting started)
OPENROUTER_API_KEY=sk-or-v1-...
# Suggested free model: meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to SQLite in the backend directory
# DATABASE_URL=sqlite:///./career_studio.db

# ── Server / CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (for production)
# CORS_ORIGINS=https://your-frontend.vercel.app,https://your-other-domain.com

# ── Auth ─────────────────────────────────────────────────────────────────────
# Change this in production! Any random long string works.
SECRET_KEY=ai-career-studio-dev-secret-change-me-in-prod

# ── Optional: Adzuna Job Board ───────────────────────────────────────────────
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
